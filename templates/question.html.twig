{% extends 'base/base.html.twig' %}

{% block title %}

{% endblock %}

{% block stylesheets %}

{% endblock %}

{% block body %}

<style>
    :root {
        --dark-navy: #0a192f;
        --accent-gold: #c5a059;
        --text-silver: #e6f1ff;
    }
    .hero-section {
        background: radial-gradient(circle at center, #112240 0%, var(--dark-navy) 100%);
        color: var(--text-silver);
        font-family: 'Georgia', serif;
    }
    /* プログレスバーのカスタマイズ */
    .progress-container {
        width: 100%;
        max-width: 800px;
        height: 2px;
        background: rgba(197, 160, 89, 0.1);
        margin-bottom: 4rem;
        position: relative;
    }
    #progress-bar {
        height: 100%;
        background: var(--accent-gold);
        width: 0%;
        transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 0 10px var(--accent-gold);
    }
    .question-card {
        max-width: 800px;
        width: 100%;
        min-height: 450px;
    }
    .choice-btn {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(197, 160, 89, 0.2);
        color: var(--text-silver);
        padding: 1.2rem 2rem;
        margin-bottom: 1rem;
        transition: all 0.3s;
        text-align: left;
        display: block;
        width: 100%;
        cursor: pointer;
    }
    .choice-btn:hover {
        background: rgba(197, 160, 89, 0.1);
        border-color: var(--accent-gold);
        transform: translateX(10px);
        color: var(--accent-gold);
    }
    .hidden { display: none !important; }
</style>

<div class="hero-section min-vh-100 d-flex flex-column align-items-center justify-content-center py-5">
    <div class="progress-container">
        <div id="progress-bar"></div>
        <div id="scene-counter" class="text-uppercase small mt-3 text-center" style="color: var(--accent-gold); letter-spacing: 0.3rem;">
            Scene 1 / 10
        </div>
    </div>

    <div id="question-area" class="question-card text-center">
        <h2 id="question-title" class="display-6 fw-light mb-5" style="line-height: 1.5; border-left: 2px solid var(--accent-gold); padding-left: 2rem; text-align: left;">

        </h2>
        <div id="question-text" class="display-8 fw-light mb-5" style="line-height: 1.5; border-left: 2px solid var(--accent-gold); padding-left: 2rem; text-align: left;">

        </div>

        <div id="choices-container" class="mt-5">

        </div>
    </div>

    <div id="finish-area" class="question-card text-center hidden">

         {{form_start(form)}}
            {{form_widget(form.question1)}}
            {{form_widget(form.question2)}}
            {{form_widget(form.question3)}}
            {{form_widget(form.question4)}}
            {{form_widget(form.question5)}}
            {{form_widget(form.question6)}}
            {{form_widget(form.question7)}}
            {{form_widget(form.question8)}}
            {{form_widget(form.question9)}}
            {{form_widget(form.question10)}}
            {{form_widget(form.question11)}}
            {{form_widget(form.question12)}}
            {{form_widget(form.question13)}}
            {{form_widget(form.question14)}}
            {{form_widget(form.question15)}}

            <h2 class="display-4 fw-light mb-4">お疲れ様でした。</h2>
            <p class="lead mb-5" style="color: rgba(230, 241, 255, 0.6); font-style: italic;">
                "The rest is silence." - あなたの魂の配役が決まりました。
            </p>

            {{form_widget(form.submit)}}
        {{form_end(form)}}
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {

    let questionJson = JSON.parse( '{{ questionJson|escape("js") }}' );

    const questions = Array.from({ length: 10 }, (_, i) => ({
        id: i + 1,
        title: questionJson[ i ].questionName,
        text:  questionJson[ i ].questionDescription,
        choices: [
            [
                questionJson[ i ].choices[0].choice,
                questionJson[ i ].choices[0].choiceId,
            ],
            [
                questionJson[ i ].choices[1].choice,
                questionJson[ i ].choices[1].choiceId,
            ],
            [
                questionJson[ i ].choices[2].choice,
                questionJson[ i ].choices[2].choiceId,
            ],
            [
                questionJson[ i ].choices[3].choice,
                questionJson[ i ].choices[3].choiceId,
            ],
        ]
    }));

    let currentIndex = 0;

    const progressBar = document.getElementById('progress-bar');
    const sceneCounter = document.getElementById('scene-counter');
    const questionText = document.getElementById('question-text');
    const questionTitle = document.getElementById('question-title');
    const choicesContainer = document.getElementById('choices-container');
    const questionArea = document.getElementById('question-area');
    const finishArea = document.getElementById('finish-area');
    let questionQuestion1 = document.getElementById('question_question1');
    let questionQuestion2 = document.getElementById('question_question2');
    let questionQuestion3 = document.getElementById('question_question3');
    let questionQuestion4 = document.getElementById('question_question4');
    let questionQuestion5 = document.getElementById('question_question5');
    let questionQuestion6 = document.getElementById('question_question6');
    let questionQuestion7 = document.getElementById('question_question7');
    let questionQuestion8 = document.getElementById('question_question8');
    let questionQuestion9 = document.getElementById('question_question9');
    let questionQuestion10 = document.getElementById('question_question10');
    let questionQuestion11 = document.getElementById('question_question11');
    let questionQuestion12 = document.getElementById('question_question12');
    let questionQuestion13 = document.getElementById('question_question13');
    let questionQuestion14 = document.getElementById('question_question14');
    let questionQuestion15 = document.getElementById('question_question15');

    function updateQuestion() {
        if (currentIndex >= questions.length) {
            showFinish();
            return;
        }

        const q = questions[currentIndex];

        // 進捗更新
        const progress = ((currentIndex + 1) / questions.length) * 100;
        progressBar.style.width = `${progress}%`;
        sceneCounter.textContent = `Scene ${currentIndex + 1} / ${questions.length}`;

        // テキスト更新
        questionTitle.textContent = q.title;
        questionText.textContent = q.text;

        // 選択肢生成
        choicesContainer.innerHTML = '';
        q.choices.forEach((choice, index) => {
            const btn = document.createElement('div');
            btn.className = 'choice-btn';
            btn.setAttribute('question', q.id);
            btn.setAttribute('choice', index);
            btn.setAttribute('my-custom-attr', q.id);
            {# btn.dataChoice = index; #}
            btn.innerHTML = `<span style="opacity:0.5; margin-right:1rem;">${index + 1}.</span> ${choice[0]}`;
            btn.onclick = () => {
                currentIndex++;
                updateQuestion();
                let question = Number(btn.getAttribute('question'));
                let choice = Number(btn.getAttribute('choice'));

                // Question1
                if (question === 1) {
                    console.log(q.choices[choice][1]);
                    questionQuestion1.value = q.choices[choice][1];
                }

                // Question2
                if (question === 2) {
                    console.log(q.choices[choice][1]);
                    questionQuestion2.value = q.choices[choice][1];
                }

                // Question3
                if (question === 3) {
                    console.log(q.choices[choice][1]);
                    questionQuestion3.value = q.choices[choice][1];
                }

                // Question4
                if (question === 4) {
                    console.log(q.choices[choice][1]);
                    questionQuestion4.value = q.choices[choice][1];
                }

                // Question5
                if (question === 5) {
                    console.log(q.choices[choice][1]);
                    questionQuestion5.value = q.choices[choice][1];
                }

                // Question6
                if (question === 6) {
                    console.log(q.choices[choice][1]);
                    questionQuestion6.value = q.choices[choice][1];
                }

                // Question7
                if (question === 7) {
                    console.log(q.choices[choice][1]);
                    questionQuestion7.value = q.choices[choice][1];
                }

                // Question8
                if (question === 8) {
                    console.log(q.choices[choice][1]);
                    questionQuestion8.value = q.choices[choice][1];
                }

                // Question9
                if (question === 9) {
                    console.log(q.choices[choice][1]);
                    questionQuestion9.value = q.choices[choice][1];
                }

                // Question10
                if (question === 10) {
                    console.log(q.choices[choice][1]);
                    questionQuestion10.value = q.choices[choice][1];
                }

                // Question11
                if (question === 11) {
                    console.log(q.choices[choice][1]);
                    questionQuestion11.value = q.choices[choice][1];
                }

                // Question12
                if (question === 12) {
                    console.log(q.choices[choice][1]);
                    questionQuestion12.value = q.choices[choice][1];
                }

                // Question13
                if (question === 13) {
                    console.log(q.choices[choice][1]);
                    questionQuestion13.value = q.choices[choice][1];
                }

                // Question14
                if (question === 14) {
                    console.log(q.choices[choice][1]);
                    questionQuestion14.value = q.choices[choice][1];
                }

                // Question15
                if (question === 15) {
                    console.log(q.choices[choice][1]);
                    questionQuestion15.value = q.choices[choice][1];
                }
            };
            choicesContainer.appendChild(btn);
        });
    }

    function showFinish() {
        questionArea.classList.add('hidden');
        finishArea.classList.remove('hidden');
        progressBar.style.width = '100%';
        sceneCounter.textContent = 'Curtain Call';
    }

    updateQuestion();
});
</script>

{% endblock %}

