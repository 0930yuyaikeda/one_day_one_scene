{% extends 'base/base.html.twig' %}

{% block title %}

{% endblock %}

{% block stylesheets %}

{% endblock %}

{% block body %}

<style>
    :root {
        --dark-bg: #02050a;
        --accent-gold: #c5a059;
        --text-silver: #e6f1ff;
    }
    .theater-bg {
        background: var(--dark-bg);
        color: var(--text-silver);
        font-family: 'Georgia', serif;
        overflow: hidden;
        height: 100vh;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        align-items: center;
        padding-top: 8vh;
    }
    .char-image-container {
        width: 200px;
        height: 200px;
        margin-left: auto;
        margin-right: auto;
        margin-bottom: 4rem;
        border: 1px solid rgba(197, 160, 89, 0.3);
        padding: 8px;
        background: rgba(0, 0, 0, 0.3);
        opacity: 0;
        transition: all 1s cubic-bezier(0.22, 1, 0.36, 1);
        transform: scale(0.9);
    }
    .char-image-active {
        opacity: 1;
        transform: scale(1);
        box-shadow: 0 0 50px rgba(197, 160, 89, 0.4);
    }
    .char-image { width: 100%; height: 100%; object-fit: cover; filter: sepia(30%); }
    
    .script-container { width: 100%; perspective: 1000px; }
    .line-box {
        transition: all 1.2s cubic-bezier(0.22, 1, 0.36, 1);
        opacity: 0;
        transform: translateY(30px);
        margin: 3rem 0;
        text-align: center;
    }
    .line-active { opacity: 1; transform: translateY(0); color: var(--accent-gold); }
    .line-past { opacity: 0.1; transform: translateY(-30px); filter: blur(2px); }

    /* 終演（Fin）のスタイル */
    #fin-display {
        display: none;
        font-size: 5rem;
        letter-spacing: 2rem;
        color: var(--accent-gold);
        text-transform: uppercase;
        opacity: 0;
        transition: opacity 2s ease-in;
        margin-top: 2rem;
    }

    .hidden { display: none !important; }
</style>

<div class="theater-bg p-4">
    <div class="performance-stage text-center">
        <div id="char-image-stage" class="char-image-container ">
            <img id="char-image" src="{{ asset('img/sample.png') }}" class="char-image">
        </div>

        <div id="script-stage" class="script-container"></div>

        <div id="fin-display">終演</div>
    </div>

    <div class="fixed-bottom p-5 text-center">
        <button id="next-trigger" class="btn btn-outline-warning text-uppercase" style="letter-spacing: 0.2rem;">
            Next Line
        </button>
        <a href="" id="next-step-btn" class="btn btn-gold px-5 py-3 text-uppercase hidden" style="letter-spacing: 0.4rem;">
            Next
        </a>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    // サンプルデータ
    const lines = [
        { speaker: 'ト書き', text: '第三幕第一場', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ト書き', text: '石造りの廊下には、いくつか天窓が設置してあり、まるで暗闇に射すスポットライトのようである。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ト書き', text: 'オフィーリアが佇んでいる。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ト書き', text: 'ハムレット、神妙な面持ちで登場。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'オフィーリア', text: '「ハムレット様。この頃、お体はいかがでいらっしゃいますか?」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '「これはご親切に。ありがとう、ありがとう、元気だ。」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'オフィーリア', text: '「ハムレット様、以前いただきましたもの、前からお返ししようと思っていました。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'オフィーリア', text: 'どうかお納めください。」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '「いや、なんのことだ?何もやった憶えはない。」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'オフィーリア', text: '「ハムレット様、憶えてらっしゃるはずです。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'オフィーリア', text: '優しいお言葉もあればこそ大切に思ってまいりましたのに、その香りもなくなりました。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'オフィーリア', text: 'お返しいたします。くださった方のお気持ちが変われば、', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'オフィーリア', text: 'どんな贈り物も貧しいものになってしまいます。本当に正しい心なら。」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ト書き', text: 'オフィーリア、胸の内からペンダントを取り出し、ハムレットに差し出す。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '「オフィーリア。本当にそう思っているのか。貴様。」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'オフィーリア', text: '「え?」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '「貴様は美しいか?」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'オフィーリア', text: '「なぜそんなことを?」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '「貴様が正直者なら、正直さと美しさは口をきかせるな。」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'オフィーリア', text: '「そうでしょうか?美しさは正直者にこそ、ふさわしいのでは?」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '「いや、とんでもない。女の正直さと美しさは両立しない。現に俺は歴とした証拠を見た。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: 'オフィーリア、かつては君を心から愛していた。」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'オフィーリア', text: '「ハムレット様。わたくしも本当に信じておりました。」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '「(叫ぶ)信じたのが間違いだ。貴様を愛したことなどない。」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'オフィーリア', text: '「わたくしは、また騙されて...。」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '「尼寺へ行け。罪人を産みたいのか?俺はこれでもまともな人間のつもりだ。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: 'それでも、いっそ母が産んでくれなければ良かったと思うほどの罪は、山ほどある。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '傲慢で、執念深く、野心家だ。いますぐにも罪を犯しかねない。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: 'そいつを思いつく頭も、それに輪郭を与える想像力も、それを実行に移す時間も', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '足りないくらいだ。俺みたいな男どもが、この世界で一体何を、しでかすか?', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '俺たちはみんな嘘つきだ。誰一人信じるな。尼寺へ行け、さあ。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '... 貴様の親父はどこにいる?」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'オフィーリア', text: '「(嘘をつく)... 家におります。」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '「(嘘に気づいて)しっかり閉じ込めておけ。馬鹿な道化を演じないようにな。では失敬する。」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ト書き', text: 'ハムレット、廊下の奥へ歩き出す。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'オフィーリア', text: '「ああ、神様。ハムレット様をお救いください。」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ト書き', text: 'ハムレット、歩みを翻してオフィーリアに近づく、', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ト書き', text: 'オフィーリア、後退り、やがて壁に追い込まれる。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '「もし結婚するなら、持参金代りに呪いの言葉をくれてやる。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: 'たとえ貴様が氷のように清らかで、雪のように純潔でも、世間の中傷は免れない。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '尼寺へ行け。俺はもう行く。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: 'どうしても結婚したいなら阿呆と結婚しろ。でなければ行け、尼寺へ。さっさと行くんだ、', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: 'もう会うことはない。」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'オフィーリア', text: '「神様、正気に戻してさしあげて。」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '「ちゃんと知ってるぞ、貴様ら女の化粧のこともな。神様からさずかった顔があるのに、', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '全く別物の仮面をつくりあげる。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '手を握って、膝を汚して、したったらずな甘ったれた口をきく。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '神のおつくりになったものに妙なあだ名をつける。ふしだらをしでかしておいて、', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '『いけなかったの?』と見え透いたことを。糞、もううんざりだ。おかげで気が狂った。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '結婚なんてものはこの世から消えてなくなれ。すでに結婚しているものは仕方がない。', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ハムレット', text: '生かしておいてやる。奴らを除いてはな。他の者は今のままでいろ。行け、尼寺へ。」', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'オフィーリア', text: '気高いお心が壊れてしまった!', image: '{{ asset('img/sample.png') }}' },
        { speaker: 'ト書き', text: 'オフィーリア、崩れ落ちる。', image: '{{ asset('img/sample.png') }}' },
    ];

    let currentLine = 0;
    const stage = document.getElementById('script-stage');
    const imageStage = document.getElementById('char-image-stage');
    const charImage = document.getElementById('char-image');
    const trigger = document.getElementById('next-trigger');
    const finDisplay = document.getElementById('fin-display');
    const nextBtn = document.getElementById('next-step-btn');

    function renderLine(index) {
        if (index >= lines.length) {
            // 全ての台詞が終了した時の処理
            trigger.classList.add('hidden');
            imageStage.classList.remove('char-image-active');
            
            // 最後の台詞も消す
            const lastLines = stage.querySelectorAll('.line-box');
            lastLines.forEach(el => el.classList.add('line-past'));

            // 終演を表示
            setTimeout(() => {
                stage.classList.add('hidden');
                finDisplay.style.display = 'block';
                setTimeout(() => {
                    finDisplay.style.opacity = '1';
                    nextBtn.classList.remove('hidden');
                }, 100);
            }, 1000);
            return;
        }

        const lineData = lines[index];
        
        // 画像更新
        imageStage.classList.remove('char-image-active');
        charImage.src = lineData.image;
        setTimeout(() => imageStage.classList.add('char-image-active'), 100);

        // 台詞更新
        const oldLines = stage.querySelectorAll('.line-box');
        oldLines.forEach(el => {
            el.classList.remove('line-active');
            el.classList.add('line-past');
        });

        const lineEl = document.createElement('div');
        lineEl.className = 'line-box line-active';
        lineEl.innerHTML = `<span class="small opacity-50 d-block">${lineData.speaker}</span><div class="h2 italic">"${lineData.text}"</div>`;
        stage.appendChild(lineEl);

        if (stage.children.length > 2) stage.removeChild(stage.firstChild);
    }

    trigger.addEventListener('click', () => {
        renderLine(currentLine);
        currentLine++;
    });

    renderLine(currentLine);
    currentLine++;
});
</script>

{% endblock %}

{% block javascripts %}


{% endblock %}
